VITE_ANTHROPIC_API_KEY=your_key_here

# Optional: full API origin (e.g. https://your-api.example). If unset during `npm run dev`, requests use /api and
# Vite proxies to Railway (see vite.config.js / VITE_DEV_PROXY_TARGET). Set to empty string to force offline demo.
# VITE_API_URL=
# VITE_DEV_PROXY_TARGET=https://yourdomi-server-production.up.railway.app
