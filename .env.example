VITE_ANTHROPIC_API_KEY=your_key_here

# Optional: full API origin (e.g. https://your-api.example). If unset during `npm run dev`, requests use /api and
# Vite proxies to Railway (see vite.config.js / VITE_DEV_PROXY_TARGET). Set to empty string to force offline demo.
# VITE_API_URL=
# VITE_DEV_PROXY_TARGET=https://yourdomi-server-production.up.railway.app

# Optional: ms pause between Nominatim geocode requests (default 1100). Lower only with self-hosted Nominatim; public OSM policy is ~1 req/s.
# VITE_NOMINATIM_GAP_MS=1100

# Map: if the API returns coordinates on each pand (e.g. lat/lng or latitude/longitude on the JSON object or in JSON:API attributes), the app uses them and skips Nominatim for those rows.
